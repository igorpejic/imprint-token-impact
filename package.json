{
  "name": "imprint-codex-monitor",
  "version": "0.1.0",
  "private": true,
  "description": "A local environmental monitor for Codex usage.",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "VITE_DEV_SERVER_URL=http://localhost:5173 concurrently -k \"vite --strictPort\" \"wait-on tcp:5173 && electron .\"",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -b"
  },
  "dependencies": {
    "@vitejs/plugin-react": "latest",
    "chokidar": "latest",
    "electron": "latest",
    "lucide-react": "latest",
    "react": "latest",
    "react-dom": "latest",
    "vite": "latest"
  },
  "devDependencies": {
    "@types/node": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "concurrently": "latest",
    "typescript": "latest",
    "vitest": "latest",
    "wait-on": "latest"
  }
}
